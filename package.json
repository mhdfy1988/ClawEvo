{
  "name": "openclaw-compact-context",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Context engine skeleton for OpenClaw",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts check:internal",
    "check:internal": "npm run check:workspace:internal && npm run check:repo",
    "check:repo": "node ./scripts/repo-tsc-task.mjs check",
    "build": "npm run build:workspace",
    "check:workspace": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts check:workspace:internal",
    "check:workspace:internal": "node ./scripts/run-workspace-plan.mjs check pack",
    "check:workspace:shared": "node ./scripts/run-workspace-plan.mjs check shared",
    "check:workspace:shells": "node ./scripts/run-workspace-plan.mjs check shells",
    "check:workspace:apps": "node ./scripts/run-workspace-plan.mjs check apps",
    "check:workspace:packages": "node ./scripts/run-workspace-plan.mjs check packages",
    "build:workspace": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts build:workspace:internal",
    "build:workspace:internal": "node ./scripts/run-workspace-plan.mjs build pack",
    "build:workspace:shared": "node ./scripts/run-workspace-plan.mjs build shared",
    "build:workspace:shells": "node ./scripts/run-workspace-plan.mjs build shells",
    "build:workspace:apps": "node ./scripts/run-workspace-plan.mjs build apps",
    "build:workspace:packages": "node ./scripts/run-workspace-plan.mjs build packages",
    "pack:workspace": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts pack:workspace:internal",
    "pack:workspace:internal": "node ./scripts/pack-workspaces.mjs",
    "pack:release": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts pack:release:internal",
    "pack:release:internal": "npm run build:workspace:apps && node ./scripts/pack-workspaces-release.mjs release --out-dir artifacts/releases",
    "pack:release:plugin": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts pack:release:plugin:internal",
    "pack:release:plugin:internal": "npm run build:workspace:apps && node ./scripts/pack-workspaces-release.mjs @openclaw-compact-context/compact-context --out-dir artifacts/releases",
    "pack:release:control-plane": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts pack:release:control-plane:internal",
    "pack:release:control-plane:internal": "npm run build:workspace:apps && node ./scripts/pack-workspaces-release.mjs @openclaw-compact-context/control-plane --out-dir artifacts/releases",
    "verify:install:compact-context": "node ./scripts/verify-compact-context-install.mjs --pack",
    "verify:install:compact-context:global": "node ./scripts/verify-compact-context-install.mjs --pack --global-only",
    "verify:install:compact-context:openclaw": "node ./scripts/verify-compact-context-install.mjs --pack --openclaw-only",
    "prepare:test:packages": "npm run build:workspace:packages",
    "test": "npm run test:packages && npm run test:apps && npm run test:smoke:required && npm run test:evaluation",
    "test:packages": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:packages:internal",
    "test:packages:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label packages --group package:contracts --group package:llm-toolkit --group package:runtime-core --group package:control-plane-core --group package:openclaw-adapter --group package:control-plane-shell",
    "test:package:contracts": "npm run test --workspace @openclaw-compact-context/contracts",
    "test:package:contracts:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-contracts --group package:contracts",
    "test:package:llm-toolkit": "npm run test --workspace @openclaw-compact-context/llm-toolkit",
    "test:package:llm-toolkit:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-llm-toolkit --group package:llm-toolkit",
    "test:package:runtime-core": "npm run test --workspace @openclaw-compact-context/runtime-core",
    "test:package:runtime-core:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-runtime-core --group package:runtime-core",
    "test:package:control-plane-core": "npm run test --workspace @openclaw-compact-context/control-plane-core",
    "test:package:control-plane-core:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-control-plane-core --group package:control-plane-core",
    "test:package:openclaw-adapter": "npm run test --workspace @openclaw-compact-context/openclaw-adapter",
    "test:package:openclaw-adapter:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-openclaw-adapter --group package:openclaw-adapter",
    "test:package:control-plane-shell": "npm run test --workspace @openclaw-compact-context/control-plane-shell",
    "test:package:control-plane-shell:internal": "node ./scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-control-plane-shell --group package:control-plane-shell",
    "test:apps": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:apps:internal",
    "test:apps:internal": "node ./scripts/run-compiled-tests.mjs --prepare build:workspace:apps --label apps --group app:openclaw-plugin --group app:control-plane",
    "test:app:openclaw-plugin": "npm run test --workspace @openclaw-compact-context/compact-context",
    "test:app:openclaw-plugin:internal": "node ./scripts/run-compiled-tests.mjs --prepare build:workspace:apps --label app-openclaw-plugin --group app:openclaw-plugin",
    "test:app:control-plane": "npm run test --workspace @openclaw-compact-context/control-plane",
    "test:app:control-plane:internal": "node ./scripts/run-compiled-tests.mjs --prepare build:workspace:apps --label app-control-plane --group app:control-plane",
    "test:context-processing": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:context-processing:internal",
    "test:context-processing:internal": "node ./scripts/repo-tsc-task.mjs build && node --test --test-concurrency=1 dist/tests/context-processing-contracts.test.js dist/tests/context-processing-pipeline.test.js dist/tests/utterance-parser.test.js dist/tests/concept-normalizer.test.js dist/tests/noise-policy.test.js dist/tests/summary-planner.test.js dist/tests/context-processing-experience.test.js dist/tests/context-processing-harness.test.js dist/tests/semantic-spans.test.js",
    "test:evaluation": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:evaluation:internal",
    "test:evaluation:internal": "node ./scripts/repo-tsc-task.mjs build && node ./scripts/run-test-group.mjs evaluation",
    "test:smoke:debug": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:smoke:debug:internal",
    "test:smoke:debug:internal": "node ./scripts/repo-tsc-task.mjs build && node --test --test-concurrency=1 dist/tests/debug-smoke.test.js",
    "test:smoke:required": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:smoke:required:internal",
    "test:smoke:required:internal": "node ./scripts/run-compiled-tests.mjs --prepare build:workspace:apps --label smoke-required --group smoke:required",
    "test:smoke:release": "node ./scripts/run-locked-npm-script.mjs workspace-artifacts test:smoke:release:internal",
    "test:smoke:release:internal": "node ./scripts/run-compiled-tests.mjs --prepare build:workspace:apps --prepare pack:workspace:internal --label smoke-release --group smoke:release",
    "test:smoke:root": "npm run test:smoke:required",
    "test:smoke:workspace": "npm run test:smoke:required",
    "describe:workspace:graph": "node ./scripts/describe-workspace-graph.mjs",
    "describe:src:convergence": "node ./scripts/src-convergence-dashboard.mjs",
    "benchmark:smoke": "node ./scripts/measure-smoke-baseline.mjs",
    "start": "npm run start --workspace @openclaw-compact-context/compact-context",
    "start:plugin": "npm run start --workspace @openclaw-compact-context/compact-context",
    "start:control-plane": "npm run start --workspace @openclaw-compact-context/control-plane",
    "start:workspace:plugin": "npm run start --workspace @openclaw-compact-context/compact-context",
    "start:workspace:control-plane": "npm run start --workspace @openclaw-compact-context/control-plane"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
