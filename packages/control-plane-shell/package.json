{
  "name": "@openclaw-compact-context/control-plane-shell",
  "version": "0.1.0",
  "type": "module",
  "description": "Control-plane server shell and console entrypoints for the compact context platform",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/workspace-tsc-task.mjs build",
    "check:self": "node ../../scripts/workspace-tsc-task.mjs check",
    "build": "node ../../scripts/run-current-workspace-plan.mjs build",
    "check": "node ../../scripts/run-current-workspace-plan.mjs check",
    "prepack": "npm run build",
    "test:local": "node ../../scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-control-plane-shell --group package:control-plane-shell",
    "test": "node ../../scripts/run-current-workspace-script.mjs workspace-artifacts test:local"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./console": {
      "types": "./src/console.ts",
      "default": "./dist/console.js"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@openclaw-compact-context/contracts": "0.1.0",
    "@openclaw-compact-context/compact-context-core": "0.1.0"
  }
}
