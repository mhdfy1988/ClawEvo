{
  "name": "@openclaw-compact-context/control-plane-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared governance, import, and observability services for the compact context control plane",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check:self": "tsc -p tsconfig.json --noEmit",
    "build": "npm --prefix ../.. run build --workspace @openclaw-compact-context/contracts && node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check": "npm --prefix ../.. run build --workspace @openclaw-compact-context/contracts && tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm --prefix ../.. run test:package:control-plane-core"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./autonomy-service": {
      "types": "./src/autonomy-service.ts",
      "default": "./dist/autonomy-service.js"
    },
    "./control-plane-facade": {
      "types": "./src/control-plane-facade.ts",
      "default": "./dist/control-plane-facade.js"
    },
    "./extension-registry": {
      "types": "./src/extension-registry.ts",
      "default": "./dist/extension-registry.js"
    },
    "./governance-policy": {
      "types": "./src/governance-policy.ts",
      "default": "./dist/governance-policy.js"
    },
    "./governance-service": {
      "types": "./src/governance-service.ts",
      "default": "./dist/governance-service.js"
    },
    "./import-service": {
      "types": "./src/import-service.ts",
      "default": "./dist/import-service.js"
    },
    "./importer-registry": {
      "types": "./src/importer-registry.ts",
      "default": "./dist/importer-registry.js"
    },
    "./observability-service": {
      "types": "./src/observability-service.ts",
      "default": "./dist/observability-service.js"
    },
    "./platform-event-service": {
      "types": "./src/platform-event-service.ts",
      "default": "./dist/platform-event-service.js"
    },
    "./stage-observability-report": {
      "types": "./src/stage-observability-report.ts",
      "default": "./dist/stage-observability-report.js"
    },
    "./workspace-catalog-service": {
      "types": "./src/workspace-catalog-service.ts",
      "default": "./dist/workspace-catalog-service.js"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@openclaw-compact-context/contracts": "0.1.0"
  }
}
