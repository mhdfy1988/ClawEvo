{
  "name": "@openclaw-compact-context/openclaw-adapter",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw adapter shell and plugin entrypoints for the compact context runtime",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check:self": "tsc -p tsconfig.json --noEmit",
    "build": "npm --prefix ../.. run build --workspace @openclaw-compact-context/contracts && npm --prefix ../.. run build --workspace @openclaw-compact-context/runtime-core && npm --prefix ../.. run build --workspace @openclaw-compact-context/control-plane-core && node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check": "npm --prefix ../.. run build --workspace @openclaw-compact-context/contracts && npm --prefix ../.. run build --workspace @openclaw-compact-context/runtime-core && npm --prefix ../.. run build --workspace @openclaw-compact-context/control-plane-core && tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm --prefix ../.. run test:package:openclaw-adapter"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./openclaw": {
      "types": "./src/openclaw/index.ts",
      "default": "./dist/openclaw/index.js"
    },
    "./bin": {
      "types": "./src/bin/openclaw-context-plugin.ts",
      "default": "./dist/bin/openclaw-context-plugin.js"
    },
    "./adapters/openclaw": {
      "types": "./src/openclaw/index.ts",
      "default": "./dist/openclaw/index.js"
    },
    "./openclaw/context-engine-adapter": {
      "types": "./src/openclaw/context-engine-adapter.ts",
      "default": "./dist/openclaw/context-engine-adapter.js"
    },
    "./openclaw/control-plane-runtime-bridge": {
      "types": "./src/openclaw/control-plane-runtime-bridge.ts",
      "default": "./dist/openclaw/control-plane-runtime-bridge.js"
    },
    "./openclaw/hook-coordinator": {
      "types": "./src/openclaw/hook-coordinator.ts",
      "default": "./dist/openclaw/hook-coordinator.js"
    },
    "./openclaw/index": {
      "types": "./src/openclaw/index.ts",
      "default": "./dist/openclaw/index.js"
    },
    "./openclaw/tool-result-artifact-store": {
      "types": "./src/openclaw/tool-result-artifact-store.ts",
      "default": "./dist/openclaw/tool-result-artifact-store.js"
    },
    "./openclaw/tool-result-policy": {
      "types": "./src/openclaw/tool-result-policy.ts",
      "default": "./dist/openclaw/tool-result-policy.js"
    },
    "./openclaw/transcript-loader": {
      "types": "./src/openclaw/transcript-loader.ts",
      "default": "./dist/openclaw/transcript-loader.js"
    },
    "./openclaw/types": {
      "types": "./src/openclaw/types.ts",
      "default": "./dist/openclaw/types.js"
    },
    "./plugin/api": {
      "types": "./src/plugin/api.ts",
      "default": "./dist/plugin/api.js"
    },
    "./plugin/context-engine-plugin": {
      "types": "./src/plugin/context-engine-plugin.ts",
      "default": "./dist/plugin/context-engine-plugin.js"
    },
    "./plugin/control-plane-bridge": {
      "types": "./src/plugin/control-plane-bridge.ts",
      "default": "./dist/plugin/control-plane-bridge.js"
    },
    "./plugin/stdio-server": {
      "types": "./src/plugin/stdio-server.ts",
      "default": "./dist/plugin/stdio-server.js"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@openclaw-compact-context/contracts": "0.1.0",
    "@openclaw-compact-context/control-plane-core": "0.1.0",
    "@openclaw-compact-context/runtime-core": "0.1.0"
  }
}
