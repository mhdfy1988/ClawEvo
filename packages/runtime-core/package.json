{
  "name": "@openclaw-compact-context/runtime-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared runtime core for context processing, knowledge, and persistence",
  "files": [
    "dist",
    "schema",
    "src",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/workspace-tsc-task.mjs build",
    "check:self": "node ../../scripts/workspace-tsc-task.mjs check",
    "build": "node ../../scripts/run-current-workspace-plan.mjs build",
    "check": "node ../../scripts/run-current-workspace-plan.mjs check",
    "prepack": "npm run build",
    "test:local": "node ../../scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-runtime-core --group package:runtime-core",
    "test": "node ../../scripts/run-current-workspace-script.mjs workspace-artifacts test:local"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./dist/runtime/index.js"
    },
    "./context-processing": {
      "types": "./src/context-processing/index.ts",
      "default": "./dist/context-processing/index.js"
    },
    "./governance": {
      "types": "./src/governance/index.ts",
      "default": "./dist/governance/index.js"
    },
    "./infrastructure": {
      "types": "./src/infrastructure/index.ts",
      "default": "./dist/infrastructure/index.js"
    },
    "./engine/context-engine": {
      "types": "./src/engine/context-engine.ts",
      "default": "./dist/engine/context-engine.js"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@openclaw-compact-context/contracts": "0.1.0"
  }
}
