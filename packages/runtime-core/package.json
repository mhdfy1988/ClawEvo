{
  "name": "@openclaw-compact-context/runtime-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared runtime core for context processing, knowledge, and persistence",
  "files": [
    "dist",
    "schema",
    "src",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check:self": "tsc -p tsconfig.json --noEmit",
    "build": "npm --prefix ../.. run build --workspace @openclaw-compact-context/contracts && node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check": "npm --prefix ../.. run build --workspace @openclaw-compact-context/contracts && tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm --prefix ../.. run test:package:runtime-core"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./dist/runtime/index.js"
    },
    "./context-processing": {
      "types": "./src/context-processing/index.ts",
      "default": "./dist/context-processing/index.js"
    },
    "./governance": {
      "types": "./src/governance/index.ts",
      "default": "./dist/governance/index.js"
    },
    "./infrastructure": {
      "types": "./src/infrastructure/index.ts",
      "default": "./dist/infrastructure/index.js"
    },
    "./engine/context-engine": {
      "types": "./src/engine/context-engine.ts",
      "default": "./dist/engine/context-engine.js"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@openclaw-compact-context/contracts": "0.1.0"
  }
}
