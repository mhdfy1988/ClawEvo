    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm --prefix ../.. run test:package:contracts"
  },
  "main": "./dist/contracts/index.js",
  "exports": {
    ".": {
      "types": "./dist/contracts/index.d.ts",
