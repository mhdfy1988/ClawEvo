{
  "name": "@openclaw-compact-context/contracts",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared contracts and types for the compact context runtime and platform",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/workspace-tsc-task.mjs build",
    "check:self": "node ../../scripts/workspace-tsc-task.mjs check",
    "build": "node ../../scripts/run-current-workspace-plan.mjs build",
    "check": "node ../../scripts/run-current-workspace-plan.mjs check",
    "prepack": "npm run build",
    "test:local": "node ../../scripts/run-compiled-tests.mjs --prepare prepare:test:packages --label package-contracts --group package:contracts",
