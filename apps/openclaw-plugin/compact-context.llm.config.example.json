{
  "catalog": {
    "providerOrder": [
      "codex-cli",
      "codex-oauth",
      "openai-responses",
      "custom-responses",
      "bailian",
      "volcengine",
      "ollama-local",
      "lm-studio-local",
      "copilot-oauth"
    ],
    "providers": {
      "codex-cli": {  
        "enabled": true,
        "status": "implemented",
        "label": "Codex CLI",
        "vendor": "OpenAI Codex",
        "auth": "cli",
        "api": "codex-cli",
        "notes": "复用本机已登录的 Codex CLI，不走 HTTP baseUrl。",
        "models": [
          {
            "id": "gpt-5-codex",
            "name": "GPT-5 Codex",
            "reasoning": true,
            "input": ["text"],
            "notes": "当前项目本地实验优先使用。"
          }
        ]
      },
      "codex-oauth": {  
        "enabled": true,
        "status": "experimental",
        "label": "Codex OAuth",
        "vendor": "OpenAI / ChatGPT",
        "auth": "oauth",
        "api": "openai-codex-responses",
        "notes": "对齐 OpenClaw 的 openai-codex 语义：这是一条独立的 Codex OAuth transport，不是普通 openai-responses。",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT-5.4",
            "reasoning": true,
            "input": ["text", "image"]
          }
        ]
      },
      "openai-responses": {
        "enabled": true,
        "status": "implemented",
        "label": "OpenAI Responses",
        "vendor": "OpenAI",
        "auth": "api-key",
        "api": "openai-responses",
        "notes": "官方公开 API 路线，后续服务端部署优先考虑。",
        "models": [
          {
            "id": "gpt-5-codex",
            "name": "GPT-5 Codex",
            "reasoning": true,
            "input": ["text", "image"]
          }
        ]
      },
      "custom-responses": {
        "enabled": false,
        "status": "experimental",
        "label": "通用 Responses 兼容层",
        "vendor": "自定义 / 代理服务",
        "auth": "api-key",
        "api": "openai-compatible-responses",
        "notes": "适合已经提供 Responses 兼容接口的网关或代理服务。",
        "models": [
          {
            "id": "<your-responses-model-id>",
            "name": "Responses 兼容模型",
            "reasoning": true,
            "input": ["text", "image"]
          }
        ]
      },
      "bailian": {
        "enabled": false,
        "status": "experimental",
        "label": "阿里云百炼 / 通义千问",
        "vendor": "阿里云百炼 / DashScope",
        "auth": "api-key",
        "api": "openai-compatible-chat-completions",
        "notes": "按阿里云百炼官方模型口径，当前模板直接预填 qwen3.5-plus；仍通过 OpenAI 兼容 Chat Completions 接入。",
        "models": [
          {
            "id": "qwen3.5-plus",
            "name": "Qwen 3.5 Plus",
            "reasoning": true,
            "input": ["text", "image"]
          }
        ]
      },
      "volcengine": {
        "enabled": false,
        "status": "experimental",
        "label": "火山方舟 / 豆包",
        "vendor": "火山引擎",
        "auth": "api-key",
        "api": "openai-compatible-chat-completions",
        "notes": "火山方舟实际调用经常需要 endpoint id；展示名如 doubao-seed-2-0-pro-260215 不一定能直接当 model id，当前模板请填写你自己的 Ark endpoint id。",
        "models": [
          {
            "id": "<your-ark-endpoint-id>",
            "name": "doubao-seed-2-0-pro-260215",
            "reasoning": true,
            "input": ["text", "image"]
          }
        ]
      },
      "ollama-local": {
        "enabled": false,
        "status": "experimental",
        "label": "Ollama 本地模型",
        "vendor": "Ollama",
        "auth": "none",
        "api": "openai-compatible-chat-completions",
        "notes": "默认按本地 OpenAI 兼容入口登记，后面可以再按需要补专用 transport。",
        "models": [
          {
            "id": "<your-ollama-model>",
            "name": "本地 Ollama 模型",
            "reasoning": false,
            "input": ["text"]
          }
        ]
      },
      "lm-studio-local": {
        "enabled": false,
        "status": "experimental",
        "label": "LM Studio 本地模型",
        "vendor": "LM Studio",
        "auth": "none",
        "api": "openai-compatible-chat-completions",
        "notes": "默认按 LM Studio 本地 OpenAI 兼容入口登记。",
        "models": [
          {
            "id": "<your-lm-studio-model>",
            "name": "本地 LM Studio 模型",
            "reasoning": false,
            "input": ["text"]
          }
        ]
      },
      "copilot-oauth": {
        "enabled": false,
        "status": "planned",
        "label": "GitHub Copilot",
        "vendor": "GitHub Copilot",
        "auth": "oauth",
        "api": "custom",
        "notes": "先只保留统一配置占位；在没有确认稳定官方接入方式前，不要直接接进主链。",
        "models": [
          {
            "id": "<your-copilot-model>",
            "name": "Copilot 模型",
            "reasoning": true,
            "input": ["text"]
          }
        ]
      }
    }
  },
  "runtime": {
    "defaultModelRef": "codex-cli/gpt-5-codex",
    "providers": {
      "codex-cli": {
        "enabled": true,
        "command": "codex",
        "model": "gpt-5-codex",
        "reasoningEffort": "low"
      },
      "codex-oauth": {
        "enabled": true,
        "baseUrl": "https://chatgpt.com/backend-api",
        "model": "gpt-5.4",
        "reasoningEffort": "low",
        "systemPrompt": "You are a helpful assistant. Reply clearly and concisely."
      },
      "openai-responses": {
        "enabled": false,
        "apiKeyEnv": "OPENAI_API_KEY",
        "baseUrl": "https://api.openai.com/v1",
        "model": "gpt-5-codex",
        "reasoningEffort": "low"
      },
      "custom-responses": {
        "enabled": false,
        "apiKeyEnv": "CUSTOM_RESPONSES_API_KEY",
        "baseUrl": "https://your-compatible-responses.example.com/v1",
        "model": "<your-responses-model-id>",
        "reasoningEffort": "low"
      },
      "bailian": {
        "enabled": false,
        "apiKeyEnv": "DASHSCOPE_API_KEY",
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "model": "qwen3.5-plus",
        "reasoningEffort": "low"
      },
      "volcengine": {
        "enabled": false,
        "apiKeyEnv": "ARK_API_KEY",
        "baseUrl": "https://ark.cn-beijing.volces.com/api/v3",
        "model": "<your-ark-endpoint-id>",
        "reasoningEffort": "low"
      },
      "ollama-local": {
        "enabled": false,
        "auth": "none",
        "baseUrl": "http://127.0.0.1:11434/v1",
        "model": "<your-ollama-model>"
      },
      "lm-studio-local": {
        "enabled": false,
        "auth": "none",
        "baseUrl": "http://127.0.0.1:1234/v1",
        "model": "<your-lm-studio-model>"
      }
    }
  }
}
