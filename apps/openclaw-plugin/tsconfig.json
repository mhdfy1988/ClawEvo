{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@openclaw-compact-context/contracts": [
        "../../packages/contracts/dist/contracts/index.d.ts"
      ],
      "@openclaw-compact-context/compact-context-core": [
        "../../packages/compact-context-core/dist/index.d.ts"
      ],
      "@openclaw-compact-context/llm-toolkit": [
        "../../packages/llm-toolkit/dist/index.d.ts"
      ],
      "@openclaw-compact-context/llm-toolkit/*": [
        "../../packages/llm-toolkit/dist/*"
      ],
      "@openclaw-compact-context/openclaw-adapter": [
        "../../packages/openclaw-adapter/dist/index.d.ts"
      ],
      "@openclaw-compact-context/openclaw-adapter/*": [
        "../../packages/openclaw-adapter/dist/*"
      ],
      "@openclaw-compact-context/runtime-core": [
        "../../packages/runtime-core/dist/index.d.ts"
      ],
      "@openclaw-compact-context/runtime-core/*": [
        "../../packages/runtime-core/dist/*"
      ]
    },
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["./src/**/*.ts"]
}
