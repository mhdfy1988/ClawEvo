{
  "name": "@openclaw-compact-context/compact-context",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw runtime plugin shell for the compact context engine",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "dist",
    "compact-context.llm.config.example.json",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/workspace-tsc-task.mjs build",
    "check:self": "node ../../scripts/workspace-tsc-task.mjs check",
    "build": "node ../../scripts/run-current-workspace-plan.mjs build",
    "check": "node ../../scripts/run-current-workspace-plan.mjs check",
    "prepack": "npm run build",
    "test:local": "node ../../scripts/run-compiled-tests.mjs --prepare build:workspace:apps --label app-openclaw-plugin --group app:openclaw-plugin",
    "test": "node ../../scripts/run-current-workspace-script.mjs workspace-artifacts test:local",
    "start": "node ./dist/bin/openclaw-context-plugin.js"
  },
  "main": "./dist/index.js",
  "bin": {
    "openclaw-context-plugin": "./dist/bin/openclaw-context-plugin.js",
    "openclaw-context-cli": "./dist/bin/openclaw-context-cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@openclaw-compact-context/compact-context-core": "0.1.0",
    "@openclaw-compact-context/llm-toolkit": "0.1.0",
    "@openclaw-compact-context/openclaw-adapter": "0.1.0"
  }
}
