{
  "name": "@openclaw-compact-context/control-plane",
  "version": "0.1.0",
  "type": "module",
  "description": "Control-plane server and client shell for the compact context platform",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check:self": "tsc -p tsconfig.json --noEmit",
    "build": "npm --prefix ../.. run build --workspace @openclaw-compact-context/control-plane-shell && node ../../scripts/clean-dist.mjs ./dist && tsc -p tsconfig.json",
    "check": "npm --prefix ../.. run build --workspace @openclaw-compact-context/control-plane-shell && tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm --prefix ../.. run test:app:control-plane",
    "start": "node ./dist/bin/openclaw-control-plane.js"
  },
  "main": "./dist/index.js",
  "bin": {
    "openclaw-control-plane": "./dist/bin/openclaw-control-plane.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js"
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@openclaw-compact-context/control-plane-shell": "0.1.0"
  }
}
