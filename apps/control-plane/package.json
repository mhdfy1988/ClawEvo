{
  "name": "@openclaw-compact-context/control-plane",
  "version": "0.1.0",
  "type": "module",
  "description": "Control-plane server and client shell for the compact context platform",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:self": "node ../../scripts/workspace-tsc-task.mjs build",
    "check:self": "node ../../scripts/workspace-tsc-task.mjs check",
    "build": "node ../../scripts/run-current-workspace-plan.mjs build",
    "check": "node ../../scripts/run-current-workspace-plan.mjs check",
    "prepack": "npm run build",
    "test:local": "node ../../scripts/run-compiled-tests.mjs --prepare build:workspace:apps --label app-control-plane --group app:control-plane",
    "test": "node ../../scripts/run-current-workspace-script.mjs workspace-artifacts test:local",
    "start": "node ./dist/bin/openclaw-control-plane.js"
  },
  "main": "./dist/index.js",
  "bin": {
    "openclaw-control-plane": "./dist/bin/openclaw-control-plane.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./bin": {
      "types": "./src/bin/openclaw-control-plane.ts",
      "default": "./dist/bin/openclaw-control-plane.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@openclaw-compact-context/compact-context-core": "0.1.0",
    "@openclaw-compact-context/control-plane-shell": "0.1.0",
    "@openclaw-compact-context/openclaw-adapter": "0.1.0"
  }
}
