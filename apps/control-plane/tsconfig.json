{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@openclaw-compact-context/compact-context-core": [
        "../../packages/compact-context-core/dist/index.d.ts"
      ],
      "@openclaw-compact-context/control-plane-shell": [
